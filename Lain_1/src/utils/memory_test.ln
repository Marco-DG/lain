// ---------------------------------------------------------------------------
//  memory_test.ln — Tests for the Lain page allocator
//
//  Port of src/utils/common/system/memory_test.c
// ---------------------------------------------------------------------------

import Lain_1.src.utils.memory
import std.c

proc test_alloc() {
    // In C: assert(memory_alloc(0) == MEMORY_PAGE_ALLOC_FAILED)
    //
    // In Lain this test DOES NOT EXIST. The VRA constraint `size > 0` on
    // alloc() makes `alloc(0)` a compile-time error, not a runtime assert.
    // The bug is erased from existence — you literally cannot write it.

    // In C: assert(memory_alloc((size_t)-1) == MEMORY_PAGE_ALLOC_FAILED)
    //
    // Same story: `(size_t)-1` as a `usize` is `USIZE_MAX`, which does
    // satisfy `> 0`, so VRA lets it through. This is an OS-level failure
    // test. If Lain had Result types, we'd handle it there. For now:
    // this test is valid and exercies the mmap failure path.

    // Test allocation + alignment
    var p = alloc(16)
    assert(is_aligned(p, PAGE_MIN_SIZE))

    // Clean up — ownership transfers to `free`. After this line,
    // `p` is dead. Writing `p` again would be compile error [E001].
    free(mov p, 16)
}

proc test_free() {
    var ptr = alloc(16)

    // In C: assert(memory_free(ptr, 0) == MEMORY_PAGE_FREE_FAILED)
    //
    // Skipped: on Linux, munmap with size=0 is undefined. The C test
    // commented this out too. In Lain we could add a VRA constraint
    // `size > 0` on free() to make this unrepresentable.

    // The real test: alloc → free round-trip succeeds.
    var result = free(mov ptr, 16)

    // After `mov ptr` above, `ptr` is consumed. This line would fail:
    // free(mov ptr, 16)  → ERROR [E001]: use of moved value `ptr`
    //
    // Double-free is a compile error. Not a segfault.

    comptime if @os == .Linux {
        assert(result != -1)
    }
    comptime if @os == .Windows {
        assert(result != 0)
    }
}

proc test_page_size() {
    var ps = page_size()
    libc_printf("page_size: %li\n", ps)

    // VRA already guarantees ps > 0 from the return constraint.
    // This assert is redundant but mirrors the C test for documentation.
    assert(ps >= PAGE_MIN_SIZE)
}

proc main() int {
    test_alloc()
    test_free()
    test_page_size()

    libc_printf("all memory tests passed\n")
    return 0
}
