// Standard math utilities

func min(a i32, b i32) i32 {
    if a < b { return a }
    return b
}

func max(a i32, b i32) i32 {
    if a > b { return a }
    return b
}

// Note: abs(INT_MIN) is implementation-defined (overflow case).
// Return constraint `i32 >= 0` expresses the invariant.
func abs(x i32) i32 >= 0 {
    if x < 0 { return 0 - x }
    return x
}

func clamp(x i32, lo i32, hi i32) i32 {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}
