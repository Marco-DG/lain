import std.c

proc print_int(val i32) {
    libc_printf("%d\n", val)
}

// 'T type variables: inferred from arguments, no explicit type arg needed.
// Old syntax: func max(comptime T type, a T, b T) T { ... }
// New syntax: func max(a 'T, b 'T) 'T { ... }
func max(a 'T, b 'T) 'T {
    if a > b {
        return a
    }
    return b
}

func identity(val 'T) 'T {
    return val
}

proc main() i32 {
    print_int(max(10, 20))          // 'T = i32, inferred from args
    print_int(max(3 as i32, 7 as i32))

    var x = identity(42)
    print_int(x)
    return 0
}
