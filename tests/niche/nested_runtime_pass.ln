// D-Niche M7: nested niche cascade end-to-end runtime test.
// Verifies that case match correctly discriminates between
// inner and outer empty variants packed into the same pointer.

extern proc libc_printf(fmt *u8, ...) i32

type InnerOpt {
    Some { v *u8 }
    None
}

type OuterResult {
    Ok { value InnerOpt }
    NotFound
    Permission
    OutOfMemory
}

proc main() i32 {
    var r1 = OuterResult.NotFound
    var r2 = OuterResult.Permission
    var r3 = OuterResult.OutOfMemory
    var r4 = OuterResult.Ok(InnerOpt.None)
    var r5 = OuterResult.Ok(InnerOpt.Some("data"))

    case r1 {
        NotFound: libc_printf("r1=NotFound\n")
        Permission: libc_printf("r1=Permission BAD\n")
        OutOfMemory: libc_printf("r1=OOM BAD\n")
        Ok(v): libc_printf("r1=Ok BAD\n")
    }

    case r2 {
        NotFound: libc_printf("r2=NotFound BAD\n")
        Permission: libc_printf("r2=Permission\n")
        OutOfMemory: libc_printf("r2=OOM BAD\n")
        Ok(v): libc_printf("r2=Ok BAD\n")
    }

    case r3 {
        NotFound: libc_printf("r3=NotFound BAD\n")
        Permission: libc_printf("r3=Permission BAD\n")
        OutOfMemory: libc_printf("r3=OOM\n")
        Ok(v): libc_printf("r3=Ok BAD\n")
    }

    case r4 {
        NotFound: libc_printf("r4=NotFound BAD\n")
        Permission: libc_printf("r4=Permission BAD\n")
        OutOfMemory: libc_printf("r4=OOM BAD\n")
        Ok(v): libc_printf("r4=Ok\n")
    }

    case r5 {
        NotFound: libc_printf("r5=NotFound BAD\n")
        Permission: libc_printf("r5=Permission BAD\n")
        OutOfMemory: libc_printf("r5=OOM BAD\n")
        Ok(v): libc_printf("r5=Ok\n")
    }

    return 0
}
