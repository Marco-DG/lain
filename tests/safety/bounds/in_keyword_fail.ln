// Test: in keyword violation - should FAIL to compile
// Passing an out-of-bounds index to a function with 'in' constraint

func get(arr i32[10], i i32 in arr) i32 {
    return arr[i]
}

proc main() i32 {
    var arr i32[10] = undefined
    var x = get(arr, 15)  // ERROR: 15 is not in [0, 10)
    
    return 0
}
