// Test: in keyword for index bounds - should compile successfully
// func get(arr i32[], i i32 in arr) means i is always a valid index

func get(arr i32[10], i i32 in arr) i32 {
    return arr[i]  // Always safe - compiler knows i ∈ [0, 9]
}

proc main() i32 {
    var arr i32[10] = undefined
    arr[0] = 42
    arr[5] = 100
    
    var x = get(arr, 5)  // OK: 5 is in [0, 10)
    var y = get(arr, 0)  // OK: 0 is in [0, 10)
    
    return 0
}
