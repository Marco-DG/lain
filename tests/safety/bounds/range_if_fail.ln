func test_leak(x i32, y i32) i32 {
    if x < y {
        // x < y is true here
        require_lt(x, y)
    } else {
        // x < y is FALSE here (x >= y)
        // This should fail: requires y > x, but we have x >= y
        require_lt(x, y)
    }
    return 0
}

