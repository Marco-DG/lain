// EXPECT: [E011]
// Test: while loops are banned in pure functions (func)
// Expected: compilation should FAIL

extern proc libc_printf(fmt *u8, ...) i32

func loop_forever() i32 {
    var i = 0
    while i < 10 {       // ERROR: while not allowed in func
        i = i + 1
    }
    return i
}

proc main() i32 {
    return loop_forever()
}
