// Test: bounded while loops are allowed in pure functions (func)
// Expected: compilation should PASS

extern proc libc_printf(fmt *u8, ...) i32

func count_up(n i32) i32 {
    var i = 0
    while i < n decreasing n - i {
        i += 1
    }
    return i
}

proc main() i32 {
    libc_printf("Result: %d\n", count_up(10))
    return 0
}
