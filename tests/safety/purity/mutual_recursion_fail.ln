// F-020 regression: mutual recursion between pure functions breaks termination.
// Prior to fix: silently compiled.
// After fix: [E011] from mutual recursion detector.
// EXPECT: [E011]

func f(n i32 != 0) i32 {
    return g(n)
}

func g(n i32 != 0) i32 {
    return f(n)
}

proc main() i32 {
    return f(1)
}
