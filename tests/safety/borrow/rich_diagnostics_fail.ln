//   help: consume with `mov r` or add `defer { drop(mov r) }`

type Resource {
    id int
}

func drop(mov r Resource) {
}

proc main() int {
    var r = Resource(42)
    // Intentionally not consuming r — should get rich diagnostic
    return 0
}
