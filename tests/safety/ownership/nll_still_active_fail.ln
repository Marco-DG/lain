// Test for NLL: borrow still active because ref is used AFTER accessing owner.
// This should FAIL compilation.

type Data {
    value int
}

func get_ref(var d Data) var int {
    return var d.value
}

func consume_ref(var r int) {
    // nothing needed — just keeps ref alive
}

func read_data(d Data) int {
    return d.value
}

proc main() int {
    var data Data = undefined
    data.value = 42
    
    // get_ref borrows 'data' mutably → ref holds the borrow alive
    var ref = get_ref(var data)
    
    // This should FAIL: ref is used later, so borrow is still active
    var x = read_data(data)
    
    // ref is used here → borrow must still be alive at line above
    consume_ref(var ref)
    
    return x
}
