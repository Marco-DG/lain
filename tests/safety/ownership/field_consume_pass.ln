// Phase 5 Test: Per-field linearity — PASS
// After consuming a linear field, the remaining non-linear fields are still accessible.
// And if all linear fields are consumed, the struct is considered fully consumed.

type Resource {
    mov handle *int
    id int
}

func drop_handle(mov {handle, id} Resource) {
    // destructure to consume
}

func get_id(r Resource) int {
    return r.id
}

proc main() int {
    var p *int = 0
    var r = Resource(p, 42)
    
    // Read a non-linear field — this is fine
    var id = get_id(r)
    
    // Consume the whole struct
    drop_handle(mov r)
    
    return id
}
