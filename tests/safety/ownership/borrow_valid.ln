type Resource {
    data i32
}

func use_resource(r Resource) i32 {
    return r.data
}

func consume_resource(mov r Resource) Resource {
    return mov r
}

proc main() i32 {
    var res Resource = undefined
    res.data = 42
    
    if 1 < 2 {
        var x = use_resource(res) // borrows res
        // borrow ends here
    }
    
    consume_resource(mov res) // should be OK
    return 0
}
