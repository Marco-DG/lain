// EXPECT: [E004]
// Test for NLL cross-statement borrow checking: should FAIL compilation
// A mutable borrow captured in a variable prevents access to the owner
// while the reference is still alive (used after the owner access).

type Data {
    value i32
}

func get_ref(var d Data) var i32 {
    return var d.value
}

func read_data(d Data) i32 {
    return d.value
}

func consume_ref(var r i32) {
}

proc main() i32 {
    var data Data = undefined
    data.value = 42
    
    // get_ref borrows 'data' mutably → ref holds the borrow alive
    var ref = get_ref(var data)
    
    // This should FAIL: data is mutably borrowed by ref (ref used below)
    var x = read_data(data)
    
    // ref is still alive — used here
    consume_ref(var ref)
    
    return 0
}
