// Phase 4 Test: Direct var-expression persistent borrow — PASS
// var ref = var data.value creates a persistent borrow.
// ref is never used after declaration → NLL releases → owner accessible.

type Data {
    value i32
}

func read_data(d Data) i32 {
    return d.value
}

proc main() i32 {
    var data Data = undefined
    data.value = 42
    
    // Direct var-expression borrow — ref borrows data
    // ref is never used → NLL releases immediately
    var ref = var data.value
    
    // OK: borrow released
    var x = read_data(data)
    return x
}
