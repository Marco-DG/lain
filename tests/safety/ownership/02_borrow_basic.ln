// 02_borrow_basic.ln
// Tests borrowing rules.

type Point {
    x i32
    y i32
}

func read(p Point) i32 {
    return p.x + p.y
}

func update(var p Point) {
    p.x = p.x + 1
}

proc main() i32 {
    var p Point = undefined
    p.x = 10
    p.y = 20
    
    // Shared borrow
    var r1 = read(p)
    var r2 = read(p)
    
    // Mutable borrow
    update(var p)
    
    return p.x // Should be 11
}
