// Fix 3: var n = x.len - 1 registers n = __len_arr - 1 as two constraints:
//   n - __len_arr <= -1   and   __len_arr - n <= 1
// This enables FM to prove out[n - i] safe when i is in 0..n.
// Before Fix 3: n equality was only registered for pure x.len (delta=0).
// With Fix 3: delta=-1 is tracked, so FM can cancel n and __len_arr.

func last_n(arr i32[> 0], out i32[arr.len]) {
    var n = arr.len - 1
    for i in 0..n {
        out[n - i] = arr[i]
    }
}

proc main() i32 {
    var xs i32[4] = [1, 2, 3, 4]
    var ys i32[4] = [0, 0, 0, 0]
    last_n(xs, ys)
    return ys[1]
}
