// Phase 3 Test: Re-borrow transitivity — PASS
// ref borrows data via get_ref, ref2 borrows data via get_ref2.
// Both ref and ref2 expire before owner access → OK
// NOTE: Uses struct-level re-borrow to avoid C double-pointer issue.

type Data {
    value i32
    extra i32
}

func get_value_ref(var d Data) var i32 {
    return var d.value
}

func get_extra_ref(var d Data) var i32 {
    return var d.extra
}

func read_data(d Data) i32 {
    return d.value
}

proc main() i32 {
    var data Data = undefined
    data.value = 42
    data.extra = 10
    
    // get_value_ref borrows 'data' mutably → ref holds the borrow alive
    // But ref is never used again → NLL releases borrow
    var ref = get_value_ref(var data)
    
    // This should PASS: ref's borrow has been released (ref never used after declaration)
    var x = read_data(data)
    return x
}
