// Full concat: out i32[a.len + b.len].
// Second loop uses index j + a.len — proved by Omega Test (FM elimination).
// After eliminating j: cross-pair (j<b.len, j≥b.len) gives 0 ≤ -1 → UNSAT.

func concat(a i32[], b i32[], out i32[a.len + b.len]) {
    for i in 0..a.len {
        out[i] = a[i]
    }
    for j in 0..b.len {
        out[j + a.len] = b[j]
    }
}

proc main() i32 {
    var xs i32[2] = [1, 2]
    var ys i32[3] = [3, 4, 5]
    var zs i32[5] = [0, 0, 0, 0, 0]
    concat(xs, ys, zs)
    return zs[0]
}
