// Concat prefix: out i32[a.len + b.len] — proves out[i] < out.len in bounds.
// Monotone constraint: a.len <= out.len, so i < a.len → i < out.len.

func concat(a i32[], b i32[], out i32[a.len + b.len]) {
    for i in 0..a.len {
        out[i] = a[i]
    }
}

proc main() i32 {
    var xs i32[2] = [1, 2]
    var ys i32[3] = [3, 4, 5]
    var zs i32[5] = [0, 0, 0, 0, 0]
    concat(xs, ys, zs)
    return zs[0]
}
