// Test for true NLL: borrow released after last use of reference binding.
// This should PASS compilation — ref's last use is the declaration itself,
// so the borrow is released before read_data(data).

type Data {
    value i32
}

func get_ref(var d Data) var i32 {
    return var d.value
}

func read_data(d Data) i32 {
    return d.value
}

proc main() i32 {
    var data Data = undefined
    data.value = 42
    
    // get_ref borrows 'data' mutably → ref holds the borrow alive
    // But ref is never used again → NLL releases borrow after this statement
    var ref = get_ref(var data)
    
    // This should PASS: borrow has been released (ref never used after declaration)
    var x = read_data(data)
    
    return x
}
