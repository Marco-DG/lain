// Test for NLL: sequential temporary borrows should still PASS
// This is backward-compatibility: borrows that are not captured in variables
// are temporary and expire at end of statement.

type Counter {
    value i32
}

func read_counter(c Counter) i32 {
    return c.value
}

func increment_counter(var c Counter) {
    c.value = c.value + 1
}

proc main() i32 {
    var cnt Counter = undefined
    cnt.value = 10
    
    // Sequential temporary borrows: each borrow expires at end of statement
    var x = read_counter(cnt)
    increment_counter(var cnt)
    var y = read_counter(cnt)

    // Reads succeed; sum is not the focus of this test.
    var _x = x
    var _y = y
    return 0
}
