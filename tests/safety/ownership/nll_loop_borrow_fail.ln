// EXPECT: [E004]
// Test for NLL: borrow used after owner access keeps it alive.
// This should FAIL compilation.

type Data {
    value i32
}

func get_ref(var d Data) var i32 {
    return var d.value
}

func consume_ref(var r i32) {
    // nothing needed — just keeps ref alive
}

func read_data(d Data) i32 {
    return d.value
}

proc main() i32 {
    var data Data = undefined
    data.value = 42
    
    // get_ref borrows 'data' mutably → ref holds the borrow alive
    var ref = get_ref(var data)
    
    // This should FAIL: ref is used AFTER this line, so borrow is still active
    var x = read_data(data)
    
    // ref used here — extends the borrow past the read_data call
    consume_ref(var ref)
    
    return x
}
