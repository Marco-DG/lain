import std.result

type MyResult = Result(int, int)

proc main() int {
    var r1 = MyResult.Ok(15)
    var r2 = MyResult.Err(99)

    var x = 0
    case r1 {
        Ok(v): x = v
        Err(e): x = 0
    }

    var y = 0
    case r2 {
        Ok(v): y = v
        Err(e): y = e
    }

    return x + y
}
