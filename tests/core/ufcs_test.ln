// Tests Universal Function Call Syntax (UFCS)

type Counter {
    val i32
}

func increment(var c Counter, amount i32) {
    c.val = c.val + amount
}

func get_val(c Counter) i32 {
    return c.val
}

proc main() i32 {
    var my_counter = Counter(10)
    
    // Test UFCS passing var implictly
    my_counter.increment(5)
    
    // Test UFCS passing shared implicitly
    var final_val = my_counter.get_val()
    
    // Should be 15
    return final_val
}
