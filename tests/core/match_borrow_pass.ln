// Tests non-consuming match: case &expr doesn't consume the value
// After the borrowed match, the original variable is still usable

proc main() int {
    var x = 42
    var result = 0

    // Borrowed match: inspect x without consuming it
    case &x {
        42: result = 1
        else: result = 0
    }

    // x is still usable after borrowed match
    return x + result
}
