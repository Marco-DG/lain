extern func printf(fmt *u8, ...) i32

type Shape {
    Circle {
        radius i32
    }
    Rectangle {
        w i32
        h i32
    }
}

proc main() i32 {
    var s = Shape.Circle(10)
    
    // Access directly inside unsafe block
    unsafe {
        var r = s.Circle.radius
        printf("Radius is %d\n", r)
    }
    
    return 0
}
