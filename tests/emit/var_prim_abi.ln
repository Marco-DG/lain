// Snapshot test: var T primitive ABI.
// Verifies that:
//   - write-through emits (*out) = val
//   - read emits (*n) not bare n
//   - forwarding passes the raw pointer (no &)

proc write_int(var out i32, val i32) {
    out = val
}

func read_int(var n i32) i32 {
    return n
}

proc forward(var x i32, val i32) {
    write_int(var x, val)
}

proc main() i32 {
    return 0
}
