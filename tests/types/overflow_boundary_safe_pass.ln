// Phase 5 extended: when VRA can prove the source range fits the
// target type's range, all boundaries (var, assign, return, call arg)
// pass without warnings.

func clamp_u8(x i32 >= 0 and <= 200) u8 {
    return x as u8      // explicit cast: programmer takes responsibility
}

func double_small(x u8) u8 {
    // x in [0,255]; x+1 might overflow u8, so use saturating operator.
    return x +| 1
}

proc main() i32 {
    var a u8 = 100              // var boundary: OK
    var b u8 = double_small(a)  // call arg + return + var: OK
    a = b                       // assign boundary: same type, OK
    return 0
}
