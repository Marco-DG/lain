// Sprint 1 Phase 5 / Q-002: wrapping operator gives explicit consent
// to overflow. The result range is bounded by the operand type, so
// assigning to that type passes the boundary check.

proc main() i32 {
    var a u8 = 200
    var b u8 = 100
    var w u8 = a +% b        // wrapping: result in [0, 255]
    var s u8 = a +| b        // saturating: result in [0, 255]
    return 0
}
