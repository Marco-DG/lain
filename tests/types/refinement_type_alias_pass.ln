// Q-002 refinement type alias: `type Name = int >= lo and <= hi` is a
// user-defined refinement of int. Variables declared with the alias
// inherit the constraint and are checked at assignment.

type Pressure = int >= 0 and <= 1000
type Percent = int >= 0 and <= 100

proc main() int {
    var p Pressure = 500       // OK: 500 in [0, 1000]
    var q Percent = 75          // OK: 75 in [0, 100]
    return 0
}
