// Sprint 19.5: packed struct setter via field assignment.
// `r.pin1 = 9` emits as `r = GpioModer_set_pin1(r, 9);`

[packed]
type GpioModer {
    pin0 u2
    pin1 u2
    pin2 u2
    pin3 u2
}

proc main() int {
    var r = GpioModer(1, 2, 3, 0)
    r.pin1 = 3      // modify in place
    var p = r.pin1
    return 0
}
