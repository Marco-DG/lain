// Sprint 19: packed struct with mixed-width fields.
// Tests that non-power-of-2 bit widths layout correctly.

[packed]
type Header {
    version  u4    // bit 0-3
    flag     u1    // bit 4
    priority u3    // bit 5-7
    length   u8    // bit 8-15
}
// total: 4 + 1 + 3 + 8 = 16 bits → uint16_t

proc main() i32 {
    var h = Header(7, 1, 5, 200)
    var v = h.version    // 7
    var f = h.flag       // 1
    var p = h.priority   // 5
    var l = h.length     // 200
    return 0
}
