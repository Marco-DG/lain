// Sprint 1 Phase 3 / Q-002: `int` parameter is monomorphized at the
// call site when the argument is a sized integer wider than i32.
// `factorial` here is called with an i64 → specialized to factorial_int_i64
// where `int → i64` throughout.

func double(n int) int {
    return n + n
}

proc main() int {
    var small i32 = 100
    var big i64 = 1000000000000
    var d1 = double(small)        // no specialization (i32 = default)
    var d2 = double(big)          // specialized to double_int_i64
    return 0
}
