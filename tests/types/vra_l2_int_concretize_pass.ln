// Sprint 14 / Q-011 L2: VRA uses concrete i32 type's range per
// monomorphized instance. Sprint 1 Phase 3 already monomorphizes
// `i32 → i64` for i64 callers; combined with Sprint 2 auto-sizing,
// each instance gets correct VRA range.

func add_one(n i32) i32 {
    return n + 1
}

proc main() i32 {
    var small i32 = 100
    var big   i64 = 1000000000000
    var d1 = add_one(small)       // instance with i32=i32, VRA on i32 range
    var d2 = add_one(big)         // instance with i32=i64, VRA on i64 range
    return 0
}
