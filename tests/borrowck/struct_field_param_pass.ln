// Sprint 5 step D: returning a struct whose pointer-bearing field
// borrows from a PARAMETER (not a local) is allowed — the parameter
// outlives the function return.

type Lexer {
    text u8[:0]
    cursor i32
}

func make_lexer(src u8[:0]) Lexer {
    return Lexer(src, 0)         // OK: src is a parameter
}

proc main() i32 {
    var buf = "hello"
    var l = make_lexer(buf)
    return 0
}
