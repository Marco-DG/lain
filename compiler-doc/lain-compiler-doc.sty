% -------------------------------------------------------------------------
% Data field documentation command
% Usage: \datafield{field\_name}{C type}{semantics description}
% -------------------------------------------------------------------------
\newcommand{\datafield}[3]{%
  \noindent
  \begin{tabular}{@{}p{3.5cm}p{3cm}p{7cm}@{}}
    \texttt{#1} & \texttt{\small #2} & #3 \\
  \end{tabular}\par\smallskip
}

% -------------------------------------------------------------------------
% Struct documentation environment
% Opens a framed block for a struct; usage:
%   \begin{structdoc}{StructName}{src/file.h:line}
%     \datafield{...}{...}{...}
%   \end{structdoc}
% -------------------------------------------------------------------------
\NewDocumentEnvironment{structdoc}{m m}{%
  \vspace{0.5em}
  \noindent\rule{\linewidth}{0.8pt}
  \vspace{0.2em}
  \par\noindent
  {\textbf{\texttt{#1}}\quad\srcref{#2}}
  \vspace{0.3em}
  \par\noindent
  \begin{tabular}{@{}p{3.5cm}p{3cm}p{7cm}@{}}
    \toprule
    \textbf{Field} & \textbf{Type} & \textbf{Semantics} \\
    \midrule
}{%
    \bottomrule
  \end{tabular}
  \vspace{0.5em}
  \par\noindent\rule{\linewidth}{0.4pt}
  \vspace{0.5em}
}

% -------------------------------------------------------------------------
% Source code listings
% -------------------------------------------------------------------------

% Lain language definition (same as spec)
\lstdefinelanguage{Lain}{
  morekeywords = {
    func, proc, var, mov, shared, return, if, else, while, for, in,
    case, import, module, struct, enum, type, unsafe, comptime, defer,
    ref, mut, true, false, and, or, not, as, decreasing, end,
    extern, c_include
  },
  morekeywords = [2]{
    int, u8, u16, u32, u64, usize, i8, i16, i32, i64, isize,
    f32, f64, bool, void
  },
  sensitive     = true,
  morecomment   = [l]{//},
  morecomment   = [s]{/*}{*/},
  morestring    = [b]",
  morestring    = [b]',
}

\lstdefinestyle{lain}{
  language        = Lain,
  basicstyle      = \ttfamily\small,
  keywordstyle    = \bfseries\color{lain-keyword},
  keywordstyle    = [2]\color{lain-type},
  commentstyle    = \itshape\color{lain-comment},
  stringstyle     = \color{lain-string},
  backgroundcolor = \color{lain-lightgrey},
  frame           = single,
  framerule       = 0.4pt,
  rulecolor       = \color{lain-grey},
  numbers         = left,
  numberstyle     = \tiny\color{lain-grey},
  stepnumber      = 1,
  numbersep       = 6pt,
  tabsize         = 4,
  showstringspaces= false,
  breaklines      = true,
  captionpos      = b,
  xleftmargin     = 2em,
}
\lstnewenvironment{laincode}[1][]{\lstset{style=lain,#1}}{}
\newcommand{\lain}[1]{\lstinline[style=lain]{#1}}

% C source code (compiler implementation)
\lstdefinestyle{cstyle}{
  language        = C,
  basicstyle      = \ttfamily\small,
  keywordstyle    = \bfseries\color{lain-blue},
  commentstyle    = \itshape\color{lain-comment},
  stringstyle     = \color{lain-string},
  backgroundcolor = \color{ccode-bg},
  frame           = single,
  framerule       = 0.4pt,
  rulecolor       = \color{lain-grey},
  numbers         = left,
  numberstyle     = \tiny\color{lain-grey},
  stepnumber      = 1,
  numbersep       = 6pt,
  tabsize         = 4,
  showstringspaces= false,
  breaklines      = true,
  captionpos      = b,
  xleftmargin     = 2em,
}
\lstnewenvironment{ccode}[1][]{\lstset{style=cstyle,#1}}{}
\newcommand{\cname}[1]{\texttt{\small #1}}

% Generated C output (what the compiler emits)
\lstdefinestyle{gencstyle}{
  language        = C,
  basicstyle      = \ttfamily\small,
  keywordstyle    = \color{lain-green}\bfseries,
  commentstyle    = \itshape\color{lain-comment},
  backgroundcolor = \color{gencode-bg},
  frame           = single,
  framerule       = 0.6pt,
  rulecolor       = \color{lain-green},
  numbers         = none,
  tabsize         = 4,
  showstringspaces= false,
  breaklines      = true,
  captionpos      = b,
  xleftmargin     = 2em,
}
\lstnewenvironment{gencode}[1][]{\lstset{style=gencstyle,#1}}{}

