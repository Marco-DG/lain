% -------------------------------------------------------------------------
% Hyperref setup
% -------------------------------------------------------------------------
\hypersetup{
  colorlinks  = true,
  linkcolor   = lain-blue,
  citecolor   = lain-blue,
  urlcolor    = lain-blue,
  pdftitle    = {The Lain Compiler --- Implementation Reference},
  pdfauthor   = {},
  pdfsubject  = {Compiler Implementation},
  bookmarksnumbered = true,
  bookmarksopen     = true,
}

% -------------------------------------------------------------------------
% Page headers
% -------------------------------------------------------------------------
\pagestyle{fancy}
\fancyhf{}
\fancyhead[LE]{\small\itshape The Lain Compiler}
\fancyhead[RO]{\small\itshape\nouppercase{\leftmark}}
\fancyfoot[C]{\small\thepage}
\renewcommand{\headrulewidth}{0.4pt}

% -------------------------------------------------------------------------
% Section formatting
% -------------------------------------------------------------------------
\titleformat{\chapter}[display]
  {\normalfont\Large\bfseries\color{lain-blue}}
  {\chaptertitlename\ \thechapter}{12pt}{\Huge}
\titleformat{\section}{\normalfont\large\bfseries\color{lain-blue}}{\thesection}{1em}{}
\titleformat{\subsection}{\normalfont\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalfont\normalsize\itshape}{\thesubsubsection}{1em}{}

% -------------------------------------------------------------------------
% Paragraph numbering (same ISO style as spec)
% -------------------------------------------------------------------------
\newcounter{pnumctr}[section]
\newcommand{\pnum}{%
  \refstepcounter{pnumctr}%
  \noindent\llap{\textcolor{lain-grey}{\scriptsize\thepnumctr\quad}}%
}

% -------------------------------------------------------------------------
% Cross-reference commands (spec-compatible + new ones)
% -------------------------------------------------------------------------
% \secref{label} — reference to a section in THIS document
\newcommand{\secref}[1]{(\S\,\ref{#1})}

% \specref{label} — reference to a section in the language spec
\newcommand{\specref}[1]{\textit{(spec~§\ref{#1})}}

% \srcref{path:line} — reference to a source file location
% Renders as a monospace link, e.g. src/sema/linearity.h:412
\newcommand{\srcref}[1]{\textcolor{srcref-color}{\texttt{\small #1}}}

% \diagcode{CODE} — inline diagnostic code
\newcommand{\diagcode}[1]{\texttt{\textbf{[#1]}}}

