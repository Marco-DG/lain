% -------------------------------------------------------------------------
% Hyperref setup
% -------------------------------------------------------------------------
\hypersetup{
  colorlinks  = true,
  linkcolor   = lain-blue,
  citecolor   = lain-blue,
  urlcolor    = lain-blue,
  pdftitle    = {The Lain Programming Language — Language Specification},
  pdfauthor   = {},
  pdfsubject  = {Language Specification},
  bookmarksnumbered = true,
  bookmarksopen     = true,
}

% -------------------------------------------------------------------------
% Page headers
% -------------------------------------------------------------------------
\pagestyle{fancy}
\fancyhf{}
\fancyhead[LE]{\small\itshape The Lain Programming Language}
\fancyhead[RO]{\small\itshape\nouppercase{\leftmark}}
\fancyfoot[C]{\small\thepage}
\renewcommand{\headrulewidth}{0.4pt}

% -------------------------------------------------------------------------
% Section formatting
% -------------------------------------------------------------------------
\titleformat{\chapter}[display]
  {\normalfont\Large\bfseries\color{lain-blue}}
  {\chaptertitlename\ \thechapter}{12pt}{\Huge}
\titleformat{\section}{\normalfont\large\bfseries\color{lain-blue}}{\thesection}{1em}{}
\titleformat{\subsection}{\normalfont\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalfont\normalsize\itshape}{\thesubsubsection}{1em}{}

% -------------------------------------------------------------------------
% Paragraph numbering (ISO style: \pnum increments a per-section counter)
% -------------------------------------------------------------------------
\newcounter{pnumctr}[section]
\newcommand{\pnum}{%
  \refstepcounter{pnumctr}%
  \noindent\llap{\textcolor{lain-grey}{\scriptsize\thepnumctr\quad}}%
}

% -------------------------------------------------------------------------
% Normative inline markers
% -------------------------------------------------------------------------
% \idbehav{description}  — implementation-defined behavior
\newcommand{\idbehav}[1]{\textit{implementation-defined}\footnote{Implementation-defined behavior: #1}}
% \undefbehav{description} — undefined behavior
\newcommand{\undefbehav}[1]{\textbf{undefined behavior}\footnote{Undefined behavior: #1}}
% \unspecbehav{description} — unspecified behavior
\newcommand{\unspecbehav}[1]{\textit{unspecified behavior}\footnote{Unspecified behavior: #1}}
% \illformed — program is ill-formed (compiler must reject)
\newcommand{\illformed}{\textit{ill-formed}}
% \wellformed — program is well-formed
\newcommand{\wellformed}{\textit{well-formed}}

% -------------------------------------------------------------------------
% Normative environments
% -------------------------------------------------------------------------

% CONSTRAINT — compiler must emit a diagnostic
\newmdenv[
  backgroundcolor = constraint-bg,
  linecolor       = constraint-border,
  linewidth       = 1.5pt,
  leftline        = true,
  rightline       = false,
  topline         = false,
  bottomline      = false,
  innerleftmargin = 8pt,
  innerrightmargin= 6pt,
  innertopmargin  = 4pt,
  innerbottommargin=4pt,
  frametitle      = {\textcolor{constraint-border}{\textbf{Constraint}}},
  frametitleaboveskip=4pt,
]{constraint}

% NOTE — informative, non-normative
\newmdenv[
  backgroundcolor = note-bg,
  linecolor       = note-border,
  linewidth       = 1pt,
  leftline        = true,
  rightline       = false,
  topline         = false,
  bottomline      = false,
  innerleftmargin = 8pt,
  innerrightmargin= 6pt,
  innertopmargin  = 4pt,
  innerbottommargin=4pt,
  frametitle      = {\textcolor{note-border}{\textbf{Note}}},
  frametitleaboveskip=4pt,
]{note}

% EXAMPLE — informative, non-normative
\newmdenv[
  backgroundcolor = example-bg,
  linecolor       = example-border,
  linewidth       = 1pt,
  leftline        = true,
  rightline       = false,
  topline         = false,
  bottomline      = false,
  innerleftmargin = 8pt,
  innerrightmargin= 6pt,
  innertopmargin  = 4pt,
  innerbottommargin=4pt,
  frametitle      = {\textcolor{example-border}{\textbf{Example}}},
  frametitleaboveskip=4pt,
]{example}

% RATIONALE — informative, design motivation
\newmdenv[
  backgroundcolor = rationale-bg,
  linecolor       = rationale-border,
  linewidth       = 1pt,
  leftline        = true,
  rightline       = false,
  topline         = false,
  bottomline      = false,
  innerleftmargin = 8pt,
  innerrightmargin= 6pt,
  innertopmargin  = 4pt,
  innerbottommargin=4pt,
  frametitle      = {\textcolor{rationale-border}{\textbf{Rationale}}},
  frametitleaboveskip=4pt,
]{rationale}

% -------------------------------------------------------------------------
% Grammar environment (BNF-style, ISO C formatting)
% -------------------------------------------------------------------------
\lstdefinelanguage{lainbnf}{
  mathescape    = true,
  basicstyle    = \ttfamily\small,
  moredelim     = [is][\itshape]{|[}{]|},
  literate      =
    {::=}{{$\mathrel{::=}$}}3
    {|}{{$\mid$}}1,
}

\lstnewenvironment{grammar}[1][]{%
  \lstset{
    language    = lainbnf,
    basicstyle  = \ttfamily\small,
    frame       = none,
    xleftmargin = 2em,
    columns     = fullflexible,
    keepspaces  = true,
    #1
  }%
}{}

% Non-terminal in grammar text: \nt{expression}
\newcommand{\nt}[1]{\textit{#1}}
% Terminal token in grammar text: \tok{func}
\newcommand{\tok}[1]{\texttt{\textbf{#1}}}

% -------------------------------------------------------------------------
% Lain source code listing
% -------------------------------------------------------------------------
\lstdefinelanguage{Lain}{
  morekeywords = {
    func, proc, var, mov, shared, return, if, else, while, for, in,
    case, import, module, struct, enum, unsafe, comptime, defer,
    ref, mut, true, false, and, or, not, as, decreasing, end
  },
  morekeywords = [2]{
    int, u8, u16, u32, u64, usize, i8, i16, i32, i64, isize,
    f32, f64, bool, str, void
  },
  sensitive     = true,
  morecomment   = [l]{//},
  morecomment   = [s]{/*}{*/},
  morestring    = [b]",
  morestring    = [b]',
}

\lstdefinestyle{lain}{
  language        = Lain,
  basicstyle      = \ttfamily\small,
  keywordstyle    = \bfseries\color{lain-keyword},
  keywordstyle    = [2]\color{lain-type},
  commentstyle    = \itshape\color{lain-comment},
  stringstyle     = \color{lain-string},
  numberstyle     = \color{lain-number},
  backgroundcolor = \color{lain-lightgrey},
  frame           = single,
  framerule       = 0.4pt,
  rulecolor       = \color{lain-grey},
  numbers         = left,
  numberstyle     = \tiny\color{lain-grey},
  stepnumber      = 1,
  numbersep       = 6pt,
  tabsize         = 4,
  showstringspaces= false,
  breaklines      = true,
  breakatwhitespace=true,
  captionpos      = b,
  xleftmargin     = 2em,
}

\lstnewenvironment{laincode}[1][]{%
  \lstset{style=lain, #1}%
}{}

% Inline Lain code: \lain{expr}
\newcommand{\lain}[1]{\lstinline[style=lain]{#1}}

% -------------------------------------------------------------------------
% Cross-reference commands
% -------------------------------------------------------------------------
% \secref{label} — reference to a clause
\newcommand{\secref}[1]{(\S\,\ref{#1})}
% \diagref{CODE} — reference to a diagnostic code
\newcommand{\diagref}[1]{\hyperref[diag:#1]{\texttt{[#1]}}}
% \gramref{rule} — reference to a grammar production
\newcommand{\gramref}[1]{\hyperref[gram:#1]{\textit{#1}}}

% -------------------------------------------------------------------------
% Diagnostic code inline display
% -------------------------------------------------------------------------
\newcommand{\diagcode}[1]{\texttt{\textbf{[#1]}}}

% -------------------------------------------------------------------------
% Standard library function spec environment
% -------------------------------------------------------------------------
\NewDocumentEnvironment{functionspec}{m m}{%
  \vspace{0.5em}
  \noindent\rule{\linewidth}{0.4pt}\\
  \textbf{#1}\quad\textit{(module \texttt{#2})}
  \vspace{0.3em}
  \par
}{%
  \par\noindent\rule{\linewidth}{0.4pt}
  \vspace{0.5em}
}
\newcommand{\synopsis}[1]{\noindent\textit{Synopsis:}\quad\lain{#1}\par}
\newcommand{\preconditions}[1]{\noindent\textit{Requires:}\quad#1\par}
\newcommand{\postconditions}[1]{\noindent\textit{Ensures:}\quad#1\par}
\newcommand{\errorcond}[1]{\noindent\textit{Errors:}\quad#1\par}

% -------------------------------------------------------------------------
% Index setup
% -------------------------------------------------------------------------
\makeindex[columns=2, title=Index, intoc]

